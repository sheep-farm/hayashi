// Wooldridge (Introductory Econometrics, 7e), Chapter 14, Example 14.4.
// panel fixed-effects wage equation: lwage ~ union + married + d81 + d82 + d83 + d84 + d85 + d86 + d87.

load "validation/cases/panel_fe_wooldridge_wagepan_ch14/data/wagepan.csv" as df

xtset(df, nr, year)
let m = fe(lwage ~ union + married + d81 + d82 + d83 + d84 + d85 + d86 + d87, df)

export(m, "txt", "/dev/stdout")
