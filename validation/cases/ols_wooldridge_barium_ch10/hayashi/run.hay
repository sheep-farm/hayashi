// Wooldridge (Introductory Econometrics, 7e), Chapter 10, Example 10.5.
// barium chloride import demand and antidumping filings: lchnimp ~ lchempi + lgas + lrtwex + befile6 + affile6 + afdec6.

load "validation/cases/ols_wooldridge_barium_ch10/data/barium.csv" as df

let m = ols(lchnimp ~ lchempi + lgas + lrtwex + befile6 + affile6 + afdec6, df)

export(m, "csv", "/dev/stdout")
