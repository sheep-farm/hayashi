// Generate deterministic AR(1) data from Chapter 26 DGP.
seed(42)
input df
id
1
end
for i in 1..=9 { df = append(df, df) }
df |> filter(_n <= 500)
generate df e = rnormal()
generate df t = _n
let n = nrow(df)
generate df y = 0.0
let i = 2
while i <= n {
    let lag_y = mean(df, y, if = t == i - 1)
    let et    = mean(df, e, if = t == i)
    replace df y = 0.7 * lag_y + et if t == i
    i = i + 1
}
export(df, "csv", "validation/cases/ar_book/data/ar.csv")
