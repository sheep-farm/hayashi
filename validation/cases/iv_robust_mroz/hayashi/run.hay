// Load the Wooldridge mroz dataset from CSV.
// The dataset is generated by the reference scripts before this script runs.
load "validation/cases/iv_robust_mroz/data/mroz.csv" as df

// Wooldridge Chapter 15 returns-to-schooling IV with robust standard errors.
let m = iv(lwage ~ educ + exper + expersq, ~ fatheduc + motheduc + exper + expersq, df, cov=robust)

export(m, "txt", "/dev/stdout")
