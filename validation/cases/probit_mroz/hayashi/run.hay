// Load the Wooldridge mroz dataset from CSV.
load "validation/cases/probit_mroz/data/mroz.csv" as df

// Labour-force participation probit.
let m = probit(inlf ~ nwifeinc + educ + exper + age + kidslt6 + kidsge6, df)

// Export coefficient table for automated comparison.
export(m, "txt", "/dev/stdout")
