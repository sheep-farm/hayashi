// Wooldridge (Introductory Econometrics, 7e), Chapter 7, Example 7.1.
// hourly wage equation with a qualitative dummy variable: wage ~ female + educ + exper + tenure.

load "validation/cases/ols_wooldridge_wage1_female_ch7/data/wage1.csv" as df

let m = ols(wage ~ female + educ + exper + tenure, df)

export(m, "csv", "/dev/stdout")
