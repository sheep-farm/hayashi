// Load the deterministic simulated Fama-MacBeth panel generated by the
// reference scripts.
load "validation/cases/fmb_simulated/data/fmb_panel.csv" as df

// Greeners' Fama-MacBeth implementation expects a floating-point time column.
generate df fperiod = period + 0.0

// Classic Fama-MacBeth regression: cross-sectional OLS by period, followed by
// time-series averaging of coefficients and FM standard errors.
fmb(ret ~ beta + size, df, time=fperiod)
