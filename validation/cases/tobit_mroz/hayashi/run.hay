// Load the Wooldridge mroz dataset from CSV.
load "validation/cases/tobit_mroz/data/mroz.csv" as df

// Tobit model of hours worked, censored at zero.
let m = tobit(hours ~ nwifeinc + educ + exper + age + kidslt6 + kidsge6, df, ll=0)

// Export coefficient table for automated comparison.
export(m, "txt", "/dev/stdout")
