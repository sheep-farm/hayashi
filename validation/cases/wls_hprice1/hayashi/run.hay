// Load the Wooldridge hprice1 dataset from CSV.
load "validation/cases/wls_hprice1/data/hprice1.csv" as df

// Generate the weight column inside Hayashi: w = 1 / lotsize.
generate df w = 1 / lotsize

// Estimate weighted least squares with weights proportional to 1/lotsize.
let m = wls(price ~ lotsize + sqrft + bdrms, df, weights="w")

// Export coefficient table for automated comparison.
export(m, "csv", "/dev/stdout")
