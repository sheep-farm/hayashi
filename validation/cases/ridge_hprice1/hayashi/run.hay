// Ridge regression of log house price on log lot size, log square footage,
// bedrooms and colonial dummy using the Wooldridge hprice1 dataset.
load "validation/cases/ridge_hprice1/data/hprice1.csv" as df

let m = ridge(lprice ~ llotsize + lsqrft + bdrms + colonial, df, alpha=0.1)

export(m, "txt", "/dev/stdout")
