// Load the Wooldridge wage1 dataset from CSV.
// The dataset is generated by the reference scripts before this script runs.
load "validation/cases/ftest_robust_wooldridge_wage1/data/wage1.csv" as df

// Estimate OLS model.
let m = ols(wage ~ educ + exper + tenure, df)

// Run robust F-test for joint significance of exper and tenure.
let f = ftest_robust(m, vars="exper,tenure")

// Export test results for automated comparison.
export(f, "txt", "/dev/stdout")
