// Load the Wooldridge wagepan dataset from CSV.
// The dataset is generated by the reference scripts before this script runs.
load "validation/cases/ols_cluster_wagepan/data/wagepan.csv" as df

// Estimate a pooled wage equation with worker-clustered standard errors.
let m = ols(lwage ~ educ + exper + expersq + union + married, df, cluster=nr)

// Export coefficient table for automated comparison.
export(m, "csv", "/dev/stdout")
