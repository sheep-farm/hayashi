// Load the Wooldridge wage1 dataset from CSV.
// The dataset is generated by the reference scripts before this script runs.
load "validation/cases/ols_hc3_wooldridge_wage1/data/wage1.csv" as df

// Estimate a log-wage equation with HC3 robust standard errors.
let m = ols(lwage ~ educ + exper + tenure, df, cov=HC3)

// Export coefficient table for automated comparison.
export(m, "csv", "/dev/stdout")
