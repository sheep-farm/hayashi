:
// Load the Wooldridge wage1 dataset from CSV.
// The dataset is generated by the reference scripts before this script runs.
load "validation/cases/ols_wooldridge_wage1/data/wage1.csv" as df

// Estimate the canonical Mincer wage equation.
let m = ols(wage ~ educ + exper + tenure, df)

// Export coefficient table for automated comparison.
export(m, "csv", "validation/cases/ols_wooldridge_wage1/hayashi/output.csv")
