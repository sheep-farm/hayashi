// Load the Wooldridge card dataset from CSV.
// The dataset is generated by the reference scripts before this script runs.
load "validation/cases/iv_cluster_card/data/card.csv" as df

// Hayashi may infer 0/1 and integer CSV columns as bool/int. Create numeric
// modelling columns so this case isolates clustered-IV covariance.
generate df feduc = educ + 0.0
generate df fexper = exper + 0.0
generate df fexpersq = expersq + 0.0
generate df fblack = black + 0.0
generate df fsouth = south + 0.0
generate df fsmsa = smsa + 0.0
generate df fnearc4 = nearc4 + 0.0

// Card returns-to-schooling IV with standard errors clustered by Census region.
let m = iv(
    lwage ~ feduc + fexper + fexpersq + fblack + fsouth + fsmsa,
    ~ fnearc4 + fexper + fexpersq + fblack + fsouth + fsmsa,
    df,
    cluster=region
)

export(m, "txt", "/dev/stdout")
