// Load the Wooldridge wagepan dataset from CSV.
// The dataset is generated by the reference scripts before this script runs.
load "validation/cases/hausman_robust_wooldridge_wagepan/data/wagepan.csv" as df

// Declare panel structure.
xtset(df, nr, year)

// Estimate FE and RE models.
let m_fe = fe(lwage ~ exper + expersq + married + union, df)
let m_re = re(lwage ~ exper + expersq + married + union, df)

// Run robust Hausman test.
let h = hausman_robust(m_fe, m_re)

// Export test results for automated comparison.
export(h, "txt", "/dev/stdout")
