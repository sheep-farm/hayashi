// Load the Wooldridge phillips dataset from CSV.
// The dataset is generated by the reference scripts before this script runs.
load "validation/cases/ols_newey_west_phillips/data/phillips.csv" as df

// Estimate the expectations-augmented Phillips curve with Newey-West SEs.
let m = ols(cinf ~ unem, df, nw=4)

// Export coefficient table for automated comparison.
export(m, "csv", "/dev/stdout")
