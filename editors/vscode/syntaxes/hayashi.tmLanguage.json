{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Hayashi",
  "scopeName": "source.hayashi",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#estimators" },
    { "include": "#operators" },
    { "include": "#formula" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.hayashi",
          "match": "//.*$"
        },
        {
          "name": "comment.line.hash.hayashi",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.hayashi",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.hayashi",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.hayashi",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.hayashi",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.hayashi",
          "match": "\\b(if|else|for|in|while|break|continue|return|fn)\\b"
        },
        {
          "name": "keyword.declaration.hayashi",
          "match": "\\b(let|scalar|load|as|generate|gen|predict|replace|input|end|display|print|export)\\b"
        },
        {
          "name": "constant.language.hayashi",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "keyword.other.hayashi",
          "match": "\\b(xtset|tsset|source|do|help|set_seed|timer|preserve|restore|quietly|capture|assert)\\b"
        }
      ]
    },
    "estimators": {
      "patterns": [
        {
          "name": "entity.name.function.estimator.hayashi",
          "match": "\\b(ols|reg|regress|iv|logit|probit|poisson|nbreg|tobit|heckman|truncreg|qreg|fe|re|ab|sysgmm|pcse|xtgls|cox|km|arima|sarima|garch|egarch|gjrgarch|var|vecm|svar|lasso|ridge|elasticnet|did|rd|synth|psmatch|fmb|rlm|gee|glm|betareg|ologit|oprobit|clogit|cloglog|zip|zinb|mlogit|mixed|bootstrap|boot)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.hayashi",
          "match": "\\b(summarize|tabulate|tabstat|xtsum|ttest|correlate|pwcorr|describe|list|count|mean|sum|std|min|max|total)\\b"
        },
        {
          "name": "support.function.postestimation.hayashi",
          "match": "\\b(test|nlcom|margins|coefplot|esttab|eststo|estclear|estat|hausman|predict|lincom|vif|durbinwatson|diagnostics)\\b"
        },
        {
          "name": "support.function.data.hayashi",
          "match": "\\b(drop|keep|dropna|rename|sort|merge|append|collapse|reshape|encode|decode|winsor|winsorize|tabgen|recode|duplicates|label|ci|centile|format|portsort|doublesort)\\b"
        },
        {
          "name": "support.function.graph.hayashi",
          "match": "\\b(graph_scatter|graph_line|graph_hist|graph_coef|gscatter|gline|ghist|gcoefplot|scatter|histogram|lineplot|boxplot|kdensity|acfplot|qqplot|corrplot|residplot)\\b"
        },
        {
          "name": "support.function.math.hayashi",
          "match": "\\b(log|ln|exp|sqrt|abs|floor|ceil|round|sin|cos|tan|asin|acos|atan|sign|factorial|comb|cond|normal|invnormal|uniform|rnormal|mod|pow)\\b"
        },
        {
          "name": "support.function.string.hayashi",
          "match": "\\b(upper|lower|trim|contains|starts_with|ends_with|len|substr|split|str_replace|str|int|float|regexm|regexr|regexra|regexs)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.hayashi",
          "match": "==|!=|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.logical.hayashi",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.hayashi",
          "match": "\\+|-|\\*|/|\\^"
        },
        {
          "name": "keyword.operator.assignment.hayashi",
          "match": "="
        }
      ]
    },
    "formula": {
      "patterns": [
        {
          "name": "keyword.operator.formula.hayashi",
          "match": "~"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.special.hayashi",
          "match": "\\b(_n|_N|_cons)\\b"
        }
      ]
    }
  }
}
