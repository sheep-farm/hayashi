{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Hayashi",
  "scopeName": "source.hayashi",
  "patterns": [
    { "include": "#comments" },
    { "include": "#fstrings" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#estimators" },
    { "include": "#operators" },
    { "include": "#formula" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.hayashi",
          "match": "//.*$"
        },
        {
          "name": "comment.line.hash.hayashi",
          "match": "#.*$"
        }
      ]
    },
    "fstrings": {
      "patterns": [
        {
          "name": "string.interpolated.hayashi",
          "begin": "f\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.hayashi",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.hayashi",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                { "include": "#numbers" },
                { "include": "#variables" }
              ]
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.hayashi",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.hayashi",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.hayashi",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.hayashi",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.hayashi",
          "match": "\\b(if|else|for|in|while|break|continue|return|fn|match|try|catch)\\b"
        },
        {
          "name": "keyword.declaration.hayashi",
          "match": "\\b(let|const|scalar|load|as|generate|gen|predict|replace|input|end|display|print|export|import|source)\\b"
        },
        {
          "name": "constant.language.hayashi",
          "match": "\\b(true|false|nil)\\b"
        },
        {
          "name": "keyword.other.hayashi",
          "match": "\\b(xtset|tsset|help|set_seed|timer|preserve|restore|quietly|capture|assert)\\b"
        }
      ]
    },
    "estimators": {
      "patterns": [
        {
          "name": "entity.name.function.estimator.hayashi",
          "match": "\\b(ols|reg|regress|wls|iv|logit|probit|poisson|nbreg|tobit|heckman|heckit|qreg|fe|re|be|feiv|ab|sysgmm|pcse|xtgls|pthresh|cox|km|arima|sarima|autoreg|ardl|kalman|garch|egarch|gjrgarch|var|vecm|varma|svar|lasso|ridge|elasticnet|did|rd|fuzzy_rd|synth|psm|fmb|portsort|doublesort|rlm|gee|glm|betareg|ologit|oprobit|clogit|cpoisson|cmnlogit|zip|zinb|mlogit|mixed|bootstrap|boot|gmm|sur|sureg|three_sls|threesl|pca|factor|ucm|ets|dfm|gam|mice|lowess)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.hayashi",
          "match": "\\b(summarize|tabulate|tabstat|xtsum|ttest|correlate|pwcorr|describe|list|count|mean|sum|std|min|max|total)\\b"
        },
        {
          "name": "support.function.postestimation.hayashi",
          "match": "\\b(test|nlcom|margins|coefplot|esttab|eststo|estclear|estat|hausman|predict|lincom|vif|condnum|reset|jb|influence|drop_collinear)\\b"
        },
        {
          "name": "support.function.data.hayashi",
          "match": "\\b(drop|keep|dropna|rename|sort|filter|merge|append|collapse|reshape|encode|decode|winsor|winsorize|tabgen|recode|duplicates|label|ci|centile|format|portsort|doublesort|push|pop|insert|remove|clear|reverse|index|slice|join|map|select|unique|flatten|range|len|keys|values|has_key|dict_set|dict_remove|dict_merge|typeof|type)\\b"
        },
        {
          "name": "support.function.graph.hayashi",
          "match": "\\b(graph_scatter|graph_line|graph_hist|graph_coef|gscatter|gline|ghist|gcoefplot|scatter|histogram|lineplot|boxplot|kdensity|acfplot|qqplot|corrplot|residplot)\\b"
        },
        {
          "name": "support.function.math.hayashi",
          "match": "\\b(log|ln|exp|sqrt|abs|floor|ceil|round|sin|cos|tan|asin|acos|atan|atan2|sign|factorial|comb|cond|normal|invnormal|uniform|rnormal|mod|pow|chi2tail|ttail|invttail)\\b"
        },
        {
          "name": "support.function.string.hayashi",
          "match": "\\b(upper|lower|trim|contains|starts_with|ends_with|substr|split|str_replace|str|int|float|bool|regexm|regexr|regexra|regexs)\\b"
        },
        {
          "name": "support.function.datetime.hayashi",
          "match": "\\b(date|datetime|year|month|day|hour|minute|second|dow)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.hayashi",
          "match": "==|!=|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.logical.hayashi",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.hayashi",
          "match": "\\+|-|\\*|/|\\^"
        },
        {
          "name": "keyword.operator.pipe.hayashi",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.namespace.hayashi",
          "match": "::"
        },
        {
          "name": "keyword.operator.assignment.hayashi",
          "match": "="
        }
      ]
    },
    "formula": {
      "patterns": [
        {
          "name": "keyword.operator.formula.hayashi",
          "match": "~"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.special.hayashi",
          "match": "\\b(_n|_N|_cons)\\b"
        }
      ]
    }
  }
}
