{
  "name": "hayashi-lang",
  "displayName": "Hayashi",
  "description": "Language support for Hayashi (.hay) — applied econometrics DSL",
  "version": "0.2.0",
  "publisher": "sheep-farm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sheep-farm/hayashi"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages", "Debuggers"],
  "activationEvents": ["onDebugResolve:hayashi", "onDebugInitialConfigurations"],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "hayashi",
        "aliases": ["Hayashi", "hay"],
        "extensions": [".hay"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "hayashi",
        "scopeName": "source.hayashi",
        "path": "./syntaxes/hayashi.tmLanguage.json"
      }
    ],
    "keybindings": [
      {
        "command": "workbench.action.tasks.runTask",
        "key": "ctrl+shift+r",
        "when": "editorLangId == hayashi"
      }
    ],
    "taskDefinitions": [
      {
        "type": "hayashi",
        "properties": {
          "script": {
            "type": "string",
            "description": "The .hay file to run"
          }
        }
      }
    ],
    "debuggers": [
      {
        "type": "hayashi",
        "label": "Hayashi Debug",
        "program": "./out/extension.js",
        "runtime": "node",
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to the Hayashi script to debug.",
                "default": "${file}"
              },
              "runtimeExecutable": {
                "type": ["string", "null"],
                "description": "Path to the hay binary.",
                "default": "hay"
              },
              "runtimeArgs": {
                "type": "array",
                "description": "Command-line arguments passed to the hay binary.",
                "default": ["dap"]
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "hayashi",
            "request": "launch",
            "name": "Debug Hayashi script",
            "program": "${file}",
            "runtimeExecutable": "hay",
            "runtimeArgs": ["dap"]
          }
        ]
      }
    ]
  }
}
