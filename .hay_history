load "validation/cases/cox_heart/data/heart.csv" as df
let m = autoreg(df, time, lags=1, trend="ct")
export(m, "txt", "/dev/stdout")
load "validation/cases/cox_heart/data/heart.csv" as df
let m = arima(df, time, p=1, d=0, q=0)
export(m, "txt", "/dev/stdout")
generate df r = (time - lag(time, 1)) / lag(time, 1)
let m = garch(df, r, p=1, q=1)
export(m, "txt", "/dev/stdout")
load "validation/cases/cox_heart/data/heart.csv" as df
generate df r = (time - lag(time, 1)) / lag(time, 1)
let m = garch(df, r, p=1, q=1)
export(m, "txt", "/dev/stdout")
load "validation/cases/cox_heart/data/heart.csv" as df
let m = garch(df, time, p=1, q=1)
export(m, "txt", "/dev/stdout")
load "validation/cases/cox_heart/data/heart.csv" as df
let m = did(time ~ age, df, treat=censored, post=time)
export(m, "txt", "/dev/stdout")
load "validation/cases/cox_heart/data/heart.csv" as df
let m = var(df, time, age, lags=1)
export(m, "txt", "/dev/stdout")
