{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Hayashi",
      "type": "shell",
      "command": "${workspaceFolder}/target/release/hayashi",
      "args": ["${file}"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": {
        "owner": "hayashi",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^error: (.+) at line (\\d+)",
          "message": 1,
          "line": 2
        }
      }
    }
  ]
}
